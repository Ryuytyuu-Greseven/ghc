# MongoDB connection URI
MONGODB_URI=mongodb+srv://<db_user>:<db_password>@cluster.mongodb.net/healthcare

# Server Port
PORT=3001

# DB Credentials
DB_USER_NAME=your_db_username
DB_PASS=your_db_password

COMPASS_URL=mongodb+srv://<db_user>:<db_password>@cluster.mongodb.net/

# JWT Configuration
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=60m

# GCP Configuration
GEMINI_API_KEY=your_gemini_api_key
GOOGLE_CLOUD_PROJECT=your_project_id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_CLOUD_LOCATION_US=us-central1
GOOGLE_CLOUD_LOCATION_IN=asia-south1
GOOGLE_GENAI_USE_ENTERPRISE=True
GOOGLE_CLOUD_STT_RECOGNIZER_ID=lyreai

# login backend prod:https://ghc-login-backend-588930377639.asia-south1.run.app
